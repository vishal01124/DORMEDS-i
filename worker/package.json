{
  "name": "pharmadist-worker",
  "version": "1.0.0",
  "description": "PharmaDist Pro — Cloudflare Worker",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create pharmadist-db",
    "db:migrate": "wrangler d1 execute pharmadist-db --file=schema.sql --remote",
    "db:migrate:local": "wrangler d1 execute pharmadist-db --file=schema.sql --local",
    "secrets": "node scripts/set-secrets.js"
  },
  "dependencies": {
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "wrangler": "^3.60.0"
  }
}
