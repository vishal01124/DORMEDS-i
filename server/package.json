{
  "name": "pharmadist-server",
  "version": "2.0.0",
  "description": "PharmaDist Pro – Secure Backend Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "validate": "node -e \"require('./server.js')\" --check || true",
    "check-deps": "node -e \"const d=require('./package.json').dependencies;Object.entries(d).forEach(([k,v])=>{try{require(k);console.log('✅',k,v)}catch(e){console.error('❌ MISSING:',k,v);process.exit(1)}})\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "2.8.5",
    "express": "4.18.3",
    "express-rate-limit": "7.3.1",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "6.9.14",
    "pg": "8.12.0"
  }
}
